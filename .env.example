# Required. Use a database owned by this installation.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
SESSION_SECRET=replace-with-a-long-random-value
FIELD_ENCRYPTION_KEY=replace-with-64-hex-characters

# Set to this installation's bare hostname, without a scheme or path.
APP_DOMAIN=your-domain.example

# Leave APP_ENV unset for a normal Replit workspace/deployment. The app
# resolves workspace runs to dev and Replit Deployments to prod.
# APP_ENV=dev

# Temporary first-admin bootstrap credential. Remove it after bootstrap if
# disaster-recovery setup access is not intentionally being retained.
SETUP_SECRET=replace-with-a-long-random-value

# Optional integrations. Use credentials owned by this installation only.
SENDGRID_API_KEY=
SENTRY_DSN=
VITE_SENTRY_DSN=
BN_API_KEY=
LOG_LEVEL=debug

