modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000

[[ports]]
localPort = 5001
externalPort = 80

[[ports]]
localPort = 5002
externalPort = 3000

[workflows]
runButton = "Dev Server"

[[workflows.workflow]]
name = "Run"
author = 39355628

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[[workflows.workflow]]
name = "Start Server"
author = 39355628

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server/index.js"

[[workflows.workflow]]
name = "Dev Server"
author = 39355628

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server/index.js"
