modules = ["nodejs-22", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001

[[ports]]
localPort = 5002
externalPort = 3000

[[ports]]
localPort = 5003
externalPort = 3001

[[ports]]
localPort = 5004
externalPort = 3002

[[ports]]
localPort = 5005
externalPort = 3003

[[ports]]
localPort = 23636
externalPort = 5000

[[ports]]
localPort = 23637
externalPort = 5173

[[ports]]
localPort = 23638
externalPort = 4200

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "csrf-coverage"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "org-isolation"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "wire-sanitization"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "not-found-code"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/setup-ssh.sh --quiet || true; npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run check"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "csrf-coverage"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run check:csrf"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "org-isolation"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run check:org-isolation"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "wire-sanitization"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/check-wire-sanitization.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "not-found-code"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/check-not-found-code.ts && npx tsx scripts/check-provider-not-configured.ts && npx tsx scripts/check-no-nested-link-button.ts"

[workflows.workflow.metadata]
isValidation = true

[deployment]
run = ["sh", "-c", "NODE_ENV=production node --import ./dist/instrument.js dist/index.js"]
deploymentTarget = "vm"
build = ["sh", "-c", "npm run build && esbuild server/instrument.ts --platform=node --packages=external --bundle --format=esm --outdir=dist"]

[userenv]

[userenv.shared]
SQUARE_PRODUCTION_APP_ID = "sq0idp-7qXqEqFgsEkS1NpNbvhyDA"
SQUARE_PRODUCTION_LOCATION_ID = "LPM9NWNXW82M5"
SENTRY_DSN = "https://424c61a13e92d32157f44e43c5d2e03f@o4511069370777600.ingest.us.sentry.io/4511069394960384"
VITE_SENTRY_DSN = "https://424c61a13e92d32157f44e43c5d2e03f@o4511069370777600.ingest.us.sentry.io/4511069394960384"

[userenv.development]
TRUST_PROXY_PROBE_TOKEN = "devonly-trustproxy-probe-token-do-not-use-in-prod-1234567890"
DEV_DB_HOST_ALLOWLIST = "ep-dawn-unit-a66zn28k"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000
