[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/setup-ssh.sh --quiet || true; npm run dev"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "NODE_ENV=production node --import ./dist/instrument.js dist/index.js"]
deploymentTarget = "vm"
build = ["sh", "-c", "npm run build && esbuild server/instrument.ts --platform=node --packages=external --bundle --format=esm --outdir=dist"]

[userenv]

[userenv.shared]
SQUARE_PRODUCTION_APP_ID = "sq0idp-7qXqEqFgsEkS1NpNbvhyDA"
SQUARE_PRODUCTION_LOCATION_ID = "LPM9NWNXW82M5"
SENTRY_DSN = "https://424c61a13e92d32157f44e43c5d2e03f@o4511069370777600.ingest.us.sentry.io/4511069394960384"
VITE_SENTRY_DSN = "https://424c61a13e92d32157f44e43c5d2e03f@o4511069370777600.ingest.us.sentry.io/4511069394960384"

[userenv.development]
