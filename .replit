modules = ["nodejs-22", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001

[[ports]]
localPort = 5002
externalPort = 3000

[[ports]]
localPort = 5003
externalPort = 3001

[[ports]]
localPort = 5004
externalPort = 3002

[[ports]]
localPort = 5005
externalPort = 3003

[[ports]]
localPort = 23636
externalPort = 5000

[[ports]]
localPort = 23637
externalPort = 5173

[[ports]]
localPort = 23638
externalPort = 4200

[workflows]
runButton = "Start application"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "wire-sanitization"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "csrf-coverage"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "extra-guards"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "not-found-code"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "knip"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run check"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "wire-sanitization"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/check-wire-sanitization.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "csrf-coverage"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run check:csrf && npm run check:org-isolation"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "extra-guards"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/check-eslint-baseline.ts --strict && npx tsx scripts/check-no-secrets-in-logs.ts --surface=server --strict && npx tsx scripts/check-no-secrets-in-logs.ts --surface=client --strict && npx tsx scripts/check-log-debug-pii.ts --strict && npx tsx scripts/check-trust-proxy-coverage.ts --strict"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "not-found-code"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/check-not-found-code.ts && npx tsx scripts/check-provider-not-configured.ts && npx tsx scripts/check-no-nested-link-button.ts && npx tsx scripts/check-error-log-guard-wiring.ts"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "knip"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx knip"

[workflows.workflow.metadata]
outputType = "console"

[deployment]
run = ["sh", "-c", "NODE_ENV=production node --import ./dist/instrument.js dist/index.js"]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm run build && esbuild server/instrument.ts --platform=node --packages=external --bundle --format=esm --outdir=dist"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
