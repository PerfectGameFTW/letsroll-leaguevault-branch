{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "server/instrument.ts",
    "server/test-entry.ts",
    "server/scripts/*.ts",
    "server/storage.ts",
    "server/storage/*.ts",
    "server/vite.ts",
    "scripts/**/*.ts",
    "shared/schema/index.ts",
    "tests/**/*.test.ts",
    "tests/**/*.test.tsx",
    "tests/setup/**/*.ts",
    "tests/fixtures/fake-square-client.ts"
  ],
  "project": [
    "client/src/**/*.{ts,tsx}",
    "server/**/*.ts",
    "shared/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "@capacitor/camera",
    "@capacitor/preferences",
    "@capacitor/splash-screen",
    "@capacitor/status-bar"
  ]
}
